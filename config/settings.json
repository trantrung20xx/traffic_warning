{
  "database": {
    "path": "config/traffic_warning.sqlite"
  },
  "camera": {
    "stream": {
      "rtsp_reconnect_delay_s": 2.0
    }
  },
  "detection": {
    "weights_path": "backend/yolov8m.pt",
    "device": "auto",
    "confidence_threshold": 0.28,
    "iou_threshold": 0.7
  },
  "tracking": {
    "tracker_config": "bytetrack.yaml",
    "vehicle_type_history": {
      "window_ms": 5000,
      "size": 12
    },
    "stable_track": {
      "max_idle_ms": 1500,
      "min_iou_for_rebind": 0.15,
      "max_normalized_distance": 1.6
    }
  },
  "lane_assignment": {
    "temporal": {
      "observation_window_ms": 1200,
      "min_majority_hits": 3,
      "switch_min_duration_ms": 700
    }
  },
  "wrong_lane": {
    "min_duration_ms": 1200
  },
  "turn_detection": {
    "turn_region_min_hits": 3,
    "turn_state_timeout_ms": 3000,
    "trajectory_history_window_ms": 2000
  },
  "evidence_fusion": {
    "line_crossing": {
      "side_tolerance_px": 2.0,
      "min_pre_frames": 2,
      "min_post_frames": 2,
      "min_displacement_px": 2.0,
      "min_displacement_ratio": 0.02,
      "max_gap_ms": 400,
      "cooldown_ms": 1200
    },
    "evidence_expire_ms": 1600,
    "motion_window_samples": 8
  },
  "event_lifecycle": {
    "violation_rearm_window_ms": 3500,
    "state_prune_max_age_s": 60.0
  },
  "geometry": {
    "evidence_crop": {
      "expand_x_ratio": 0.28,
      "expand_y_top_ratio": 0.32,
      "expand_y_bottom_ratio": 0.27,
      "min_size_px": 24
    },
    "evidence_image": {
      "jpeg_quality": 92
    }
  },
  "performance": {
    "preview": {
      "max_fps": 15.0,
      "jpeg_quality": 75
    },
    "processing": {
      "fps_window_s": 1.5
    }
  },
  "websocket": {
    "track_push_interval_ms": 200
  },
  "analytics": {
    "chart": {
      "minute_granularity_max_range_hours": 24,
      "hour_granularity_max_range_days": 3,
      "day_granularity_max_range_days": 60,
      "week_granularity_max_range_days": 120,
      "minute_axis_label_interval_minutes": 60,
      "minute_axis_max_ticks": 8,
      "hour_axis_max_ticks": 8,
      "overview_axis_max_ticks": 7,
      "point_markers_max_points": 240
    }
  },
  "logging": {
    "level": "info",
    "verbose_violation_trace": false
  },
  "debug": {
    "draw_runtime_overlays": false
  }
}
