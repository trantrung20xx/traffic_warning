{
	"database": {
		"path": "config/traffic_warning.sqlite"
	},
	"camera": {
		"stream": {
			"rtsp_reconnect_delay_s": 2.0
		}
	},
	"detection": {
		"weights_path": "backend/yolov8s.pt",
		"device": "auto",
		"confidence_threshold": 0.25,
		"iou_threshold": 0.7,
		"allowed_classes": ["motorcycle", "car", "truck", "bus"]
	},
	"tracking": {
		"tracker_config": "bytetrack.yaml",
		"vehicle_type_history": {
			"window_ms": 5000,
			"size": 12,
			"recency_weight_bias": 0.15
		},
		"stable_track": {
			"max_idle_ms": 1500,
			"min_iou_for_rebind": 0.15,
			"max_normalized_distance": 1.6
		}
	},
	"lane_assignment": {
		"temporal": {
			"observation_window_ms": 1200,
			"min_majority_hits": 3,
			"switch_min_duration_ms": 700
		},
		"overlap_preference": {
			"preferred_lane_overlap_ratio": 0.8,
			"preferred_lane_overlap_margin_px": 6.0
		}
	},
	"wrong_lane": {
		"min_duration_ms": 900
	},
	"direction_detection": {
		"defaults": {
			"same_direction_cos_threshold": 0.25,
			"opposite_direction_cos_threshold": -0.45,
			"min_duration_ms": 700,
			"min_displacement_px": 7.0,
			"min_samples": 3,
			"evaluation_window_samples": 12,
			"segment_min_displacement_px": 2.0,
			"segment_max_gap_ms": 450,
			"warmup_min_duration_ms": 0,
			"warmup_min_samples": 3,
			"opposite_consensus_min_segments": 2,
			"opposite_consensus_ratio_min": 0.55,
			"opposite_min_displacement_px": 10.0,
			"opposite_min_displacement_lane_ratio": 0.1,
			"lane_consensus_sample_window": 48,
			"lane_consensus_min_samples": 6,
			"lane_consensus_inlier_dot_min": 0.75,
			"lane_consensus_blend_weight": 0.28,
			"lane_consensus_alignment_min_dot": 0.2,
			"lane_consensus_max_age_ms": 180000,
			"trajectory_blend_weight": 0.16,
			"trajectory_blend_min_alignment_dot": 0.5
		}
	},
	"turn_detection": {
		"turn_region_min_hits": 3,
		"turn_state_timeout_ms": 3000,
		"trajectory_history_window_ms": 2000,
		"heading": {
			"straight_max_deg": 32.0,
			"turn_min_deg": 18.0,
			"turn_max_deg": 155.0,
			"u_turn_min_change_deg": 110.0,
			"side_sign_tolerance": 0.000001,
			"value_sign_tolerance": 0.00001,
			"straight_curvature_max_for_heading_support": 0.28
		},
		"curvature": {
			"u_turn_min": 0.2,
			"straight_max": 0.24,
			"turn_min": 0.04,
			"fallback_min": 0.02
		},
		"opposite_direction": {
			"cos_threshold": -0.3
		},
		"trajectory": {
			"sample_inside_polygon_min_hits": 2,
			"entry_heading_lookback_points": 4,
			"entry_heading_min_displacement_px": 8.0,
			"heading_local_window_points": 3,
			"fallback_reference": {
				"sample_window": 32,
				"min_samples": 3,
				"consensus_min": 0.78,
				"inlier_dot_min": 0.6,
				"inlier_ratio_min": 0.78,
				"max_age_ms": 180000,
				"trajectory_blend_max_weight": 0.35,
				"trajectory_blend_min_alignment_dot": 0.35
			}
		}
	},
	"evidence_fusion": {
		"line_crossing": {
			"side_tolerance_px": 2.0,
			"min_pre_frames": 2,
			"min_post_frames": 2,
			"min_displacement_px": 2.0,
			"min_displacement_ratio": 0.02,
			"max_gap_ms": 400,
			"cooldown_ms": 1200
		},
		"evidence_expire_ms": 1600,
		"motion_window_samples": 8,
		"turn_scoring": {
			"decay_per_frame": 0.18,
			"score_cap": 30.0,
			"turn_zone_hit_weight": 2.1,
			"exit_zone_hit_weight": 4.1,
			"exit_line_hit_weight": 5.2,
			"heading_support_weight": 1.3,
			"curvature_support_weight": 0.7,
			"opposite_direction_weight": 2.0,
			"temporal_continuity_bonus": 0.4,
			"no_signal_penalty": 0.35,
			"temporal_hits_min": 2,
			"strong_exit_min_temporal_hits": 2,
			"strong_exit_min_turn_zone_hits": 2,
			"threshold_turn": 4.2,
			"threshold_turn_with_exit": 4.2,
			"threshold_u_turn": 7.2,
			"threshold_u_turn_with_exit": 5.0,
			"threshold_straight": 4.5
		}
	},
	"event_lifecycle": {
		"violation_rearm_window_ms": 3500,
		"state_prune_max_age_s": 60.0
	},
	"geometry": {
		"evidence_crop": {
			"expand_x_ratio": 0.28,
			"expand_y_top_ratio": 0.32,
			"expand_y_bottom_ratio": 0.27,
			"min_size_px": 24
		},
		"evidence_image": {
			"jpeg_quality": 92
		}
	},
	"performance": {
		"preview": {
			"max_fps": 60.0,
			"jpeg_quality": 70,
			"output_width": 1920,
			"output_height": 1080
		},
		"processing": {
			"fps_window_s": 1.5
		}
	},
	"websocket": {
		"track_push_interval_ms": 150,
		"listener_queue_maxsize": 200
	},
	"ui": {
		"monitoring": {
			"trajectory": {
				"default_limit": 30,
				"min_limit": 10,
				"max_limit": 80,
				"max_points_per_vehicle": 48,
				"stale_ms": 1500,
				"min_point_distance_px": 1.5
			},
			"violation": {
				"list_max_rows": 80,
				"highlight_duration_ms": 15000
			},
			"processing_fps": {
				"stale_after_ms": 1000,
				"poll_interval_ms": 500
			}
		}
	},
	"license_plate": {
		"enabled": true,
		"detector_weights_path": "backend/license_plate_yolov8.pt",
		"detector_confidence_threshold": 0.3,
		"detector_allowed_classes": ["license_plate", "License Plates"],
		"ocr_backend": "paddleocr",
		"easyocr_lang": "en",
		"easyocr_use_gpu": true,
		"paddle_ocr_version": "PP-OCRv5",
		"paddle_text_detection_model_name": "PP-OCRv5_mobile_det",
		"paddle_text_recognition_model_name": "PP-OCRv5_mobile_rec",
		"paddle_lang": "en",
		"paddle_use_gpu": false,
		"read_interval_ms": 250,
		"min_ocr_confidence": 0.55,
		"consensus_min_hits": 2,
		"candidate_window_ms": 5000,
		"max_attempts_before_unreadable": 8,
		"crop_expand_x_ratio": 0.1,
		"crop_expand_y_ratio": 0.08,
		"image_jpeg_quality": 92,
		"violation_update_enabled": true,
		"violation_update_min_confidence": 0.55,
		"violation_update_consensus_min_hits": 2,
		"violation_update_window_ms": 10000,
		"require_clean_track_for_violation_update": true,
		"prioritize_pending_violation_ocr": true,
		"violation_update_track_max_gap_ms": 900,
		"violation_update_track_min_observations": 3,
		"violation_update_track_max_center_jump": 1.8,
		"violation_update_track_overlap_risk_iou": 0.45,
		"violation_update_track_overlap_risk_distance": 0.35
	},
	"analytics": {
		"chart": {
			"minute_granularity_max_range_hours": 24,
			"hour_granularity_max_range_days": 3,
			"day_granularity_max_range_days": 60,
			"week_granularity_max_range_days": 120,
			"minute_axis_label_interval_minutes": 60,
			"minute_axis_max_ticks": 8,
			"hour_axis_max_ticks": 8,
			"overview_axis_max_ticks": 7,
			"point_markers_max_points": 240
		}
	},
	"logging": {
		"level": "info",
		"verbose_violation_trace": false
	}
}
