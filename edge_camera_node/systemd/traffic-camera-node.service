[Unit]
Description=Traffic Warning Edge Camera Node
After=network-online.target avahi-daemon.service
Wants=network-online.target

[Service]
Type=simple
User=__RUN_USER__
WorkingDirectory=__WORKDIR__
ExecStart=__PYTHON__ -m traffic_camera_node.main --config __CONFIG__
Restart=always
RestartSec=5
KillSignal=SIGTERM
TimeoutStopSec=20
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
